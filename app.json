{
  "expo": {
    "name": "Set Vôlei",
    "slug": "SetVoleiApp",
    "scheme": "setvoleiapp",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/set_icon.png",
    "userInterfaceStyle": "light",
    "splash": {
      "image": "./assets/set_icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#ffffff"
    },
    "ios": {
      "supportsTablet": true
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#E6F4FE",
        "foregroundImage": "./assets/set_icon.png",
        "backgroundImage": "./assets/set_icon.png",
        "monochromeImage": "./assets/set_icon.png"
      }
    },
    "plugins": [
      "expo-router",
      "expo-font",
      "expo-asset",
      "expo-secure-store"
    ]
  }
}
